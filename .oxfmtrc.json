{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"printWidth": 100,
	"tabWidth": 2,
	"useTabs": true,
	"semi": true,
	"singleQuote": false,
	"trailingComma": "all",
	"bracketSpacing": true,
	"arrowParens": "always",
	"endOfLine": "lf",
	"ignorePatterns": [
		"**/dist/**",
		"**/out/**",
		"**/node_modules/**",
		".claude/**",
		"apps/experiments/**",
		"**/routeTree.gen.ts",
		"**/_generated/**"
	]
}
